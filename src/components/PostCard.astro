---
import { Image } from "astro:assets"

const { href, title, description, cover } = Astro.props
---

<article class="post-card">
	<a href={href} class="cover">
		{cover && <Image src={cover} width={200} height={200} alt="Ilustração da postagem" />}
	</a>
	<div class="text">
		<h4 class="title">
			<a href={href}>{title}</a>
		</h4>
		<p class="description">{description}</p>
	</div>
</article>

<style>
	.post-card {
		width: 300px;
		padding: 8px;
		background: #5254ca;
		border: 5px solid white;
		transition: border-color 250ms;
	}
	.cover {
		display: grid;
		place-items: center;
		width: 100%;
		height: 200px;

	}
	.post-card img {
		display: block;
		margin: 0 auto;
		height: auto;
	}
    .title {
		font-size: 1.2rem;
		margin: 0;
	}
	.title a {
		display: block;
	}
	.post-card p {
		font-size: 0.9rem;
		padding: 4px 0;
		text-align: left;
		margin-bottom: 0;
	}

	.title:hover {
		text-decoration: underline;
	}

	/*  === HOVER === */
	.post-card:hover {
		border-color: #ffff48;
		rotate: 1deg;
	}
</style>