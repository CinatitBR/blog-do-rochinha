---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate = pubDate, cover } = Astro.props;
---

<html lang="pt-BR">
	<head>
		<BaseHead title={title} description={description} image={cover} />
		<style>
			main {
				margin: 0 auto;
				width: 75ch;
			}

			main header {
				margin: 2rem 0;
				text-align: center;
			}
			main header h1 {
				margin: 0;
			}
			.date {
				font-size: 1rem;
			}
			/* :global selector makes the styling be applied to the child (<slot />) */
			.prose :global(p) {
				text-align: justify;
			}
			.prose :global(a) {
				text-decoration: underline;
				color: #1d1298;
			}
			.prose :global(img) {
				max-width: min(100%, 400px);
			}
			.cover {
				display: grid;
				place-items: center;
				width: 100%;
				max-height: 500px;
				margin-bottom: 1rem;
			}
			.cover img {
				display: block;
				max-width: 100%;
				height: auto;
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<header>
				<h1>{title}</h1>
				<span class="date"><FormattedDate date={pubDate} /> | atualizado <FormattedDate date={updatedDate} /></span>
			</header>

			<div class="cover">
				{cover && <Image src={cover} width={500} height={500} quality="max" alt="Ilustração da postagem" />}
			</div>

			<div class="prose">
				<slot />
			</div>

			<script>
				// Update footnote title to portuguese.
				const footnoteEle = document.querySelector("#footnote-label");
				if (footnoteEle != null) footnoteEle.textContent = "Rodapé";
			</script>
		</main>

		<Footer />
	</body>
</html>